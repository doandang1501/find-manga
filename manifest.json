{
  "manifest_version": 3,
  "name": "FindManga",
  "version": "1.0.0",
  "description": "Bôi đen số 6 chữ số, right-click để mở manga tương ứng.",
  "permissions": [
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
